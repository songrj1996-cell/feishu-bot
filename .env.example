# 飞书
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=

# Dify
# 注意：长连接版本不再需要 FEISHU_VERIFICATION_TOKEN / FEISHU_ENCRYPT_KEY / PORT
DIFY_API_BASE=https://api.dify.ai/v1
# /调研分析 应用（chat-messages）
DIFY_API_KEY=app-xxxxxxxxxxxxxxx
# /反馈打标 用两个应用：探路者识别列号 + 干活者打标（completion-messages）
DIFY_LLM1_KEY=app-xxxxxxxxxxxxxxx
DIFY_LLM2_KEY=app-xxxxxxxxxxxxxxx

# 可选：/反馈打标 行级并发上限（默认 5）
# TAGGING_CONCURRENCY=5
